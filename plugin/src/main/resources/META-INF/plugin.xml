<idea-plugin>
    <id>com.cloneguard</id>
    <name>CloneGuard</name>
    <vendor email="cloneguard@dev.com" url="">CloneGuard</vendor>
    <version>1.0.0</version>

    <description><![CDATA[
        CloneGuard detects all 4 types of code clones from JetBrains AI inline suggestions
        BEFORE the developer accepts them. Also supports full-file scanning and GitHub PR integration.
        <br><br>
        <b>Clone Types Detected:</b><br>
        • Type 1 — Exact Clone (identical code)<br>
        • Type 2 — Renamed Clone (same structure, different variable names)<br>
        • Type 3 — Near-Miss Clone (similar structure, minor modifications)<br>
        • Type 4 — Semantic Clone (same intent, different implementation)<br>
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.java</depends>

    <extensions defaultExtensionNs="com.intellij">

        <!-- ═══════════════════════════════════════════════
             SCENARIO 1: Ghost Text Listener
             Intercepts JetBrains AI inline suggestions
             ═══════════════════════════════════════════════ -->
        <editorFactoryListener
            implementation="com.cloneguard.listeners.InlineSuggestionListener"/>

        <!-- ═══════════════════════════════════════════════
             SCENARIO 2: Tool Window for Scan Results
             Shows clone groups panel at bottom of IDE
             ═══════════════════════════════════════════════ -->
        <toolWindow
            id="CloneGuard"
            anchor="bottom"
            factoryClass="com.cloneguard.ui.CloneGuardToolWindowFactory"
            icon="/icons/cloneguard.svg"/>

        <!-- Application-level services -->
        <applicationService
            serviceImplementation="com.cloneguard.services.CloneIndexService"/>

        <!-- Project-level services -->
        <projectService
            serviceImplementation="com.cloneguard.services.FileScannerService"/>

        <projectService
            serviceImplementation="com.cloneguard.services.PythonServerClient"/>

    </extensions>

    <actions>
        <!-- ═══════════════════════════════════════════════
             SCENARIO 2: Scan Current File action
             Under Tools → CloneGuard → Scan Current File
             ═══════════════════════════════════════════════ -->
        <group id="CloneGuardMenu" text="CloneGuard" description="CloneGuard actions">
            <add-to-group group-id="ToolsMenu" anchor="last"/>

            <action id="CloneGuard.ScanFile"
                    class="com.cloneguard.ui.ScanFileAction"
                    text="Scan Current File"
                    description="Scan the current file for all 4 clone types">
                <keyboard-shortcut keymap="$default" first-keystroke="shift ctrl G"/>
            </action>

            <action id="CloneGuard.IndexFile"
                    class="com.cloneguard.ui.IndexFileAction"
                    text="Index Current File"
                    description="Index functions in the current file for clone detection"/>
        </group>
    </actions>

</idea-plugin>
